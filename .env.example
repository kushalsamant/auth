# Canonical issuer URL; also used as the platform JWT `iss` claim.
AUTH_URL=https://auth.kvshvl.in

# NextAuth session secret; also signs platform JWTs (HS256).
# Must match PLATFORM_JWT_SECRET on platform-api and app backends.
AUTH_SECRET=replace-with-long-random-secret

# Google OAuth (Auth.js reads these automatically).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional: platform JWT lifetime in seconds (default 7200).
# AUTH_PLATFORM_JWT_TTL_SECONDS=7200

# Optional: comma-separated allowed return_to origins when app #2+ ships.
# When unset, any https://*.kvshvl.in subdomain is allowed.
# AUTH_RETURN_TO_ALLOWLIST=https://checkyourdrawings.kvshvl.in
